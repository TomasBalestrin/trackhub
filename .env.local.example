# Supabase (projeto novo e independente)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Meta
NEXT_PUBLIC_META_PIXEL_ID=seu_pixel_id_aqui
META_CAPI_ACCESS_TOKEN=seu_capi_token_aqui
META_AD_ACCOUNT_ID=act_seu_ad_account_id
META_APP_SECRET=seu_app_secret

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
WHATSAPP_GROUP_URL=https://chat.whatsapp.com/SEU_GRUPO

# Cron (Vercel Cron → /api/cron/*)
CRON_SECRET=sua_chave_secreta_cron

# Webhook (Google Apps Script → /api/webhook/sheets)
# Opcional: se ausente, o webhook aceita CRON_SECRET (retrocompat). Defina para segregar.
WEBHOOK_SECRET=sua_chave_secreta_webhook
